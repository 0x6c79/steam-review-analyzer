# Steam Review Analyzer - Environment Variables

# Database Configuration
DB_PATH=./data/reviews.db
# Optional: Set to specify custom database path

# Scraper Configuration
SCRAPER_MAX_CONCURRENT_REQUESTS=5
SCRAPER_DEFAULT_TIMEOUT=10
SCRAPER_MAX_RETRIES=5
SCRAPER_BACKOFF_FACTOR=1.0

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# API Configuration (FastAPI)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional ML Features (for transformers support)
# TORCH_CUDA_VISIBLE_DEVICES=
# TRANSFORMERS_DEVICE=cpu
